void reverse_words(const string& filename){ // Function to reverse words in a file
    ifstream file(filename); 
    if (!file.is_open()){
        cout << "Error opening file!" << endl;
        return;
    }
    vector<string> words; // Vector to store words
    string word;
    while (file >> word){ // Read words from file
        words.push_back(word);
    }
    cout << "Reversed words: ";
    for (int i = words.size() - 1; i >= 0; i--){ // Print words in reverse order
        cout << words[i] << " ";
    }
    cout << endl;
    file.close();
}
